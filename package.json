{
  "name": "ts-agent-core",
  "version": "1.0.0",
  "description": "从零搭一个 TypeScript Agent 运行时核心 - 主干项目",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./tools": "./dist/tools/index.js",
    "./runloop": "./dist/runloop/index.js",
    "./provider": "./dist/provider/index.js",
    "./memory": "./dist/memory/index.js",
    "./core": "./dist/core/index.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "keywords": [
    "agent",
    "llm",
    "typescript",
    "tool-calling",
    "ai",
    "function-calling"
